#!/bin/bash -l

# --------------------------------------------------------------
# Module Summary
#
# Prepare a list of software modules that are available on 
# Bunya. Include versions, arches, and desctiption. 
# Upload publicly to github.com.
# --------------------------------------------------------------

# Set environment source
# TODO config
source env/rocky8d.env

# Create log file
echo "Module Summary"

# Find all modules and create a list in the working path
echo "Gather modules..."
bash scripts/gather_modules.sh

# Process the module names
echo "Process module names..."
python3 scripts/module_keys.py

# Create a table of modules : arches
echo "Check arches..."
python3 scripts/module_arch_index.py

# Create a table of modules : versions
echo "Check versions..."
python3 scripts/module_version_index.py

# Create a table of modules : whatis
echo "Check description..."
python3 scripts/module_whatis_index.py

# Make sure output dirs exist
if [ ! -d $MODS_OUTPUT_VERSION_PATH ]
then
    mkdir -p $MODS_OUTPUT_VERSION_PATH
fi

# Create the json index of all modules with all available info
echo "Prepare json file..."
python3 scripts/prepare_list_json.py

# Create the md list of all modules with all available info
echo "Prepare md file..."
python3 scripts/prepare_list_md.py

# added.
python3 scripts/checker.py

# Change to output directory
cd $MODS_OUTPUT_REPO_PATH
git pull origin main
cp $MODS_OUTFILE_PATH/* $MODS_OUTPUT_VERSION_REPO_PATH/*
git pull
git add versions/rocky8d/*
git add versions/rocky9a/*

echo "Add and commit files..."
git add $MODS_OUTPUT_VERSION_REPO_PATH/*
# Commit to github
git commit -m "Automated commit"
git push origin main

